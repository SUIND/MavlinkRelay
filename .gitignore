# .gitignore for Qt, Python, C/C++ and ROS

# ---------- Qt / Qt Creator ----------
# Qt Creator project files
*.pro.user
*.pro.user.*
*.qmake.stash
*.pro.user.*.qbs
*.creator.user

# Generated by moc/uic/rc
moc_*.cpp
ui_*.h
qrc_*.cpp
*.qmlc

# qmake / build artifacts
Makefile
Makefile.Release
Makefile.Debug
release/
debug/
build-*/
cmake-build-*/

# ---------- C / C++ ----------
# Object, libraries, executables
*.o
*.obj
*.so
*.a
*.lib
*.dll
*.exe
*.out
*.app

# CMake
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
install_manifest.txt
compile_commands.json

# Coverage / compiler output
*.d
*.gcno
*.gcda
*.gcov
*.lst

# IDE / editor
*.suo
*.user
*.ncb
*.sdf
*.opensdf
out/

# ---------- Python ----------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*$py.class
.Python
env/
venv/
.venv/
.env
pip-wheel-metadata/
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/
dist/
build/
eggs/
*.egg-info/
.tox/

# Common editor / OS files
.vscode/
.idea/
.DS_Store
*~
*.swp
.#*

# ---------- ROS (ROS1 / ROS2 / catkin / colcon) ----------
# Build, devel, install and logs
build/
devel/
install/
log/
logs/
.rosinstall
.ros
.catkin_workspace

# ROS bag files
*.bag
*.bag.*

# Colcon specific
.colcon/

# End of file
