[Unit]
Description=EC200U-CN LTE Modem USB Enumeration Guard
After=network-pre.target
Wants=network-pre.target
Before=lte-ecm-bootstrap.service
Documentation=file:///usr/local/lib/lte-module/docs/USB-TOPOLOGY.md

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash /usr/local/lib/lte-module/lte-enum-guard.sh
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
