##############################################################################
# LTE Module Deployment Parameters
# 
# Single source of truth for all deployable configuration.
# Source this file in all scripts that need deployment parameters.
#
# Format: KEY=VALUE
# All values are STRING unless specified otherwise.
##############################################################################

# ---- Hardware Configuration ----

# USB Vendor:Product ID of the Quectel EC200U-CN modem
# Expected: 2c7c:0901
LTE_MODEM_VID_PID="2c7c:0901"

# Interface name for LTE modem (after MAC-based rename from usb0)
# MUST be "lte0" (do not change)
LTE_INTERFACE_NAME="lte0"

# USB driver binding the LTE modem in ECM mode
# MUST be "cdc_ether" (do not change)
LTE_USB_DRIVER="cdc_ether"

# ---- Network Configuration ----

# Route metric for LTE interface (lower = higher priority)
# EC200U deployment uses metric 1000 (fallback)
# Ethernet has metric 100 (primary)
# MUST be 1000 (do not change for this modem)
LTE_ROUTE_METRIC=1000

# Route metric for Ethernet interfaces (lower = higher priority)
# MUST be 100 (do not change)
ETH_ROUTE_METRIC=100

# MTU (Maximum Transmission Unit) on LTE interface
# EC200U on LTE typically supports 1400 byte MTU
# Do not exceed 1500 (standard Ethernet MTU)
LTE_MTU=1400

# Access Point Name (APN) for LTE connectivity
# Set via install.sh --apn <apn> at install time, which writes the value to /etc/lte-module/params.env
# Unset/empty = auto/default APN (primary path — modem negotiates with network automatically)
# If connectivity fails, re-run install.sh --apn <carrier-apn> with your carrier's APN
# Do NOT hardcode a carrier APN in this repo file — set it at install time only
LTE_APN=""

# ---- AT Port Discovery ----

# Seconds to wait per /dev/ttyUSB* port when probing for AT response
# Lower values speed up discovery; higher values help on slow/busy ports
AT_PROBE_TIMEOUT_S=2

# ---- Modem Behavior ----

# Maximum modem enumeration detection attempts before hardware failure
# Default deployment value: 5 retries
ENUM_GUARD_MAX_RETRIES=5

# Delay in seconds between modem enumeration detection attempts
# Default deployment value: 2 seconds
ENUM_GUARD_RETRY_DELAY=2

# Seconds to wait for modem to re-enumerate on USB after AT+CFUN=1,1 restart
# Used by ecm-bootstrap.sh when switching to ECM mode requires a modem restart
# Increase if modem is slow to come back on a specific platform
ECM_REENUM_TIMEOUT_S=30

# RAT (Radio Access Technology) lock — OPT-IN, default disabled
# 0 = auto mode: modem selects best available RAT (LTE → WCDMA → GSM fallback)
# 1 = LTE-only lock: sends AT+QNWPREFMDE=2 to force LTE-only operation
#
# TRADE-OFF: LTE lock prevents WCDMA/GSM fallback. Useful in areas with confirmed
# stable LTE coverage (lower latency, consistent behavior). RISK: modem will fail
# to register if LTE signal is unavailable — do NOT enable in marginal coverage areas.
#
# Change to LTE_RAT_LOCK_ENABLED=1 only after confirming LTE coverage at deployment site.
# scripts/verify-tuning.sh reads this flag and verifies AT+QNWPREFMDE when enabled.
LTE_RAT_LOCK_ENABLED=0

# LTE watchdog healthy-state check interval (seconds)
LTE_WATCHDOG_CHECK_INTERVAL_S=15

# LTE watchdog degraded/recovering check interval (seconds)
LTE_WATCHDOG_DEGRADED_INTERVAL_S=5

# Consecutive failed health checks before DEGRADED -> RECOVERING
LTE_WATCHDOG_GRACE_CHECKS=2

# Max external recovery levels before terminal FAILED state
LTE_WATCHDOG_MAX_RECOVERY_LEVEL=4

# ---- Logging & Evidence ----

# Directory path for runtime evidence (logs, captures, diagnostics)
# MUST start with .sisyphus/ for version control isolation
# MUST NOT be modified without orchestrator approval
EVIDENCE_DIR=".sisyphus/evidence"

# Logging level threshold
# Levels: DEBUG, INFO, WARN, ERROR, FATAL
# DEBUG = most verbose, FATAL = least verbose
LOG_LEVEL="INFO"

##############################################################################
# End of parameters
##############################################################################
