# Primary Ethernet Interface Network Configuration
# Managed by systemd-networkd
# Interface eth1: Primary NIC with metric 100 (preferred over LTE's 1000)

[Match]
Name=eth1

[Network]
DHCP=ipv4
IPv6AcceptRA=no
ConfigureWithoutCarrier=no

[DHCP]
RouteMetric=100
UseDNS=yes
UseNTP=no
SendHostname=yes

[Link]
RequiredForOnline=no
