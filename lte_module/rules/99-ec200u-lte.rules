# Udev rules for Quectel EC200U-CN USB-C LTE Modem
# ===================================================
# 
# TARGET HARDWARE:
#   - Device: Quectel EC200U-CN (7SEMI LTE USB-C modem)
#   - Vendor ID: 2c7c
#   - Product ID: 0901
#   - Interface: ECM (Ethernet over CDC)
#
# PURPOSE:
#   1. BLOCK ModemManager interference
#      ModemManager will attempt to manage the exposed ttyUSB ports for 
#      modem control, which conflicts with our custom AT command bootstrap 
#      scripts and telemetry pipelines. Setting ID_MM_DEVICE_IGNORE prevents 
#      automatic modem detection and management.
#
#   2. DISABLE USB autosuspend
#      The EC200U-CN will suspend during flight if autosuspend is enabled,
#      causing loss of telemetry, GPS, and command channels. This rule
#      forces the device to stay powered and responsive.
#
#   3. DEVICE LABELING (optional)
#      Adds a TAG for udevadm queries to help identify the modem.
#
# SCOPE:
#   This rule applies ONLY to the EC200U-CN via VID:PID matching.
#   It does NOT affect other USB devices.
#
# ===================================================

# Match ONLY the Quectel EC200U-CN
SUBSYSTEMS=="usb", ATTRS{idVendor}=="2c7c", ATTRS{idProduct}=="0901", \
    ENV{ID_MM_DEVICE_IGNORE}="1", \
    ATTR{power/control}="on", \
    ATTR{power/autosuspend_delay_ms}="-1", \
    TAG="ec200u_lte_modem", \
    SYMLINK+="ec200u-lte"

SUBSYSTEM=="usb", ATTRS{idVendor}=="2c7c", ATTRS{idProduct}=="0901", ACTION=="add", \
    RUN+="/bin/sh -c 'modprobe option; sleep 1; echo 2c7c 0901 > /sys/bus/usb-serial/drivers/option1/new_id 2>/dev/null || true'"
